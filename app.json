{
  "expo": {
    "name": "FitBite",
    "slug": "fitbite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "fitbite",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFDF6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitbite.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFDF6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.fitbite.app",
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-health-connect",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Yemeklerinizi tanımak için kameraya erişim gerekiyor."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Yemek fotoğrafı seçmek için galeri erişimi gerekiyor."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2D6A4F"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "14a58d59-57e5-48bf-98e4-73cd08414f0c"
      }
    },
    "owner": "metinimo19"
  }
}
